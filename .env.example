# Router şifresi (zorunlu). Bu dosyayı .env olarak kopyalayın:
#   cp .env.example .env
# Kurulum sonrası: ~/.config/keencli/.env
KEENETIC_PASSWORD=router_şifreniz

# Opsiyonel — AI analizi için:
# OPENROUTER_API_KEY=sk-or-...
#
# Önerilen modeller (OpenRouter slug) — test özeti: AI_MODELS.md
#   anthropic/claude-sonnet-4.6   — öncelikli
#   deepseek/deepseek-v4-pro      — ekonomik
#   google/gemini-2.5-pro         — alternatif
#   qwen/qwen3.5-plus-02-15       — bütçe
LLM_MODEL=anthropic/claude-sonnet-4.6
# LLM_TEMPERATURE=0.3   # opsiyonel; varsayılan 0.3 (0.0–2.0). Deneme: 0.7
