# Router şifresi (zorunlu). Bu dosyayı .env olarak kopyalayın:
#   cp .env.example .env
# Kurulum sonrası: ~/.config/keencli/.env
KEENETIC_PASSWORD=router_şifreniz

# Opsiyonel — AI analizi için:
# OPENROUTER_API_KEY=sk-or-...
#
# Önerilen modeller (OpenRouter slug):
#   anthropic/claude-sonnet-4.6   — öncelikli (tanı raporu kalitesi)
#   qwen/qwen3-235b-a22b          — ekonomik alternatif
#   google/gemini-2.5-pro         — farklı sağlayıcı
LLM_MODEL=anthropic/claude-sonnet-4.6
